IRA_MONGO_URI=mongodb://mongodb:27017
IRA_MONGO_DB=ira
IRA_REDIS_URI=redis://redis:6379
IRA_LOG_LEVEL=INFO
IRA_WORKER_POOL_PRIORITY_SIZE=20
IRA_WORKER_POOL_GENERAL_SIZE=50
IRA_WORKER_POOL_OVERFLOW_SIZE=30
IRA_ANALYTICS_BATCH_SIZE=100
IRA_ANALYTICS_FLUSH_INTERVAL=5.0
IRA_ANALYTICS_QUEUE_SIZE=10000
IRA_SLOW_OP_THRESHOLD_MS=100
IRA_SHUTDOWN_TIMEOUT=30
